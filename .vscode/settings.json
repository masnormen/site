{
  "js/ts.preferences.includePackageJsonAutoImports": "on",

  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["tw\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["classNames\\s*=\\s*\\{\\{[\\s\\S]*?\\}\\}", "(?<=['\"`])([^'\"`]*)(?=['\"`])"],
    ["classNames\\s*=\\s*\\{\\{([\\s\\S]*?)\\}\\}", "\"([^\"]+)\"|'([^']+)'|`([^`]+)`"]
  ],
  "tailwindCSS.lint.suggestCanonicalClasses": "ignore",

  "editor.codeActions.triggerOnFocusChange": true,

  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.importModuleSpecifierEnding": "index",

  /* Editor linter */
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },

  // Use Oxc extension for formatting and linting
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.typeAware": true,
  "oxc.unusedDisableDirectives": "warn",

  "[json][jsonc][jsonl]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },
  "[css][scss][postcss]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "always"
    }
  },

  // Other
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,

  "js/ts.tsdk": "node_modules/typescript/lib",
  "js/ts.enablePromptUseWorkspaceTsdk": true
}
