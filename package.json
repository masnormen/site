{
  "name": "site-tanstack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:tsr": "dotenvx run --convention=nextjs -- vite dev --host",
    "dev:mdx": "dotenvx run --convention=nextjs -- tsx build-mdx.ts -w",
    "dev": "concurrently -c yellow,blue --pad-prefix pnpm:dev:mdx pnpm:dev:tsr",
    "build:tsr": "dotenvx run --convention=nextjs -- vite build",
    "build:mdx": "dotenvx run --convention=nextjs -- tsx build-mdx.ts",
    "build": "pnpm build:mdx && pnpm build:tsr",
    "start": "dotenvx run --convention=nextjs -- node .output/server/index.mjs",
    "lint": "oxlint --type-aware --type-check --quiet",
    "lint:fix": "oxlint --fix --type-aware --type-check --quiet",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "quality": "pnpm run --stream '/^(lint|format)$/'",
    "quality:fix": "pnpm run --stream '/^(lint:fix|format:fix)$/'",
    "typecheck": "dotenvx run --convention=nextjs -- tsc"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@giscus/react": "^3.1.0",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.43.0",
    "@tailwindcss/vite": "^4.2.1",
    "@takumi-rs/core": "^0.73.1",
    "@takumi-rs/helpers": "^0.73.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-start": "^1.166.11",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "jotai": "^2.18.1",
    "nitro": "3.0.260311-beta",
    "p-memoize": "^8.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-innertext": "^1.1.5",
    "react-medium-image-zoom": "^5.4.1",
    "sonner": "^2.0.7",
    "srvx": "^0.11.9",
    "tailwind-merge": "^3.5.0",
    "tiny-glob": "^0.2.9",
