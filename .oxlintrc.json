{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "node", "jsdoc", "jsx-a11y", "unicorn"],
  "jsPlugins": ["@tanstack/eslint-plugin-router"],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    // "style": "warn",
    "pedantic": "off"
  },
  "rules": {
    "eslint/no-multiple-empty-lines": ["error", { "max": 1, "maxEOF": 1 }],
    "eslint/no-param-reassign": "error",
    "eslint/no-shadow": "error",
    "eslint/sort-keys": "off",
    "import/no-anonymous-default-export": "error",
    "import/no-named-as-default-member": "off",
    "import/no-unassigned-import": "off",

    "react-in-jsx-scope": "off",
    "react/exhaustive-deps": "warn",
    "jsx-a11y/label-has-associated-control": "off",
    "no-extra-boolean-cast": "off",
    "no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],

    "no-shadow": "warn",

    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-use-before-define": "off",
    "typescript/no-floating-promises": "off",
    "typescript/no-misused-promises": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/no-non-null-asserted-optional-chain": "off",
    "typescript/restrict-template-expressions": "off",
    "typescript/unbound-method": "off",
    "typescript/no-base-to-string": "off",

    "@tanstack/router/create-route-property-order": "error",
    "@tanstack/router/route-param-names": "error"
  },
  "overrides": [
    // {
    //   "files": ["packages/shared-utils/**/*", "packages/shared-ui/**/*"],
    //   "rules": {
    //     "no-anonymous-default-export": "off",
    //     "no-unused-vars": ["off", { "argsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_" }],
    //     "no-unused-expressions": "off",
    //     "unicorn/no-empty-file": "off",
    //     "typescript/no-wrapper-object-types": "off",
    //     "no-useless-escape": "off",
    //     "no-constant-binary-expression": "off",
    //     "no-extra-boolean-cast": "off",
    //     "no-extra-non-null-assertion": "off",
    //     "no-duplicate-type-constituents": "off",
    //     "no-useless-spread": "off"
    //   }
    // }
    //   {
    //     "files": ["**/*.ts", "**/*.tsx"],
    //     "rules": {
    //       "typescript/no-floating-promises": "off",
    //       "typescript/no-misused-promises": "off",
    //       "typescript/no-redundant-type-constituents": "off",
    //       "typescript/no-non-null-asserted-optional-chain": "off",
    //       "typescript/restrict-template-expressions": "off",
    //       "typescript/unbound-method": "off",
    //       "typescript/no-base-to-string": "off"
    //     }
    //   }
  ],
  "ignorePatterns": ["**/*.gen.ts", "node_modules", "cypress", "dist", ".next", ".output", "build"]
}
